<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:navigationIconTint="@color/black"
        app:title="Formulario de equipo"
        app:titleCentered="false"
        app:titleTextColor="@color/black" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Código"
                android:textColor="@color/black"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editCodigo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/primary_blue"
                android:hint="Ingrese el código"
                android:inputType="text"
                android:textColor="@color/black"
                android:textColorHint="@color/text_gray" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Nombre del equipo"
                android:textColor="@color/black"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editNombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/primary_blue"
                android:hint="Ingrese el nombre"
                android:inputType="text"
                android:textColor="@color/black"
                android:textColorHint="@color/text_gray" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Tipo de equipo"
                android:textColor="@color/black"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinnerTipoEquipo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:backgroundTint="@color/primary_blue" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Estado"
                android:textColor="@color/black"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/radioGroupEstado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/radioOperativo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Operativo"
                    android:textColor="@color/black" />

                <RadioButton
                    android:id="@+id/radioEnMantenimiento"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="En mantenimiento"
                    android:textColor="@color/black" />

                <RadioButton
                    android:id="@+id/radioFueraDeServicio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fuera de servicio"
                    android:textColor="@color/black" />

            </RadioGroup>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Observaciones"
                android:textColor="@color/black"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editObservaciones"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:backgroundTint="@color/primary_blue"
                android:gravity="top"
                android:hint="Agregue observaciones"
                android:inputType="textMultiLine"
                android:textColor="@color/black"
                android:textColorHint="@color/text_gray" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGuardar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Guardar"
                android:textAllCaps="false"
                android:textColor="@color/white"
                app:backgroundTint="@color/primary_blue"
                app:cornerRadius="14dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>